{
  "name": "github-light",
  "description": "GitHub Light Default (Primer)",
  "note": "First bundled light theme. Uses the richer hex schema: every surface has an explicit fg/bg so a dark terminal does not bleed through. Loadable as-is by dropping into ~/.config/fedit/themes/.",
  "accent": "#0969DA",
  "statusFg": "#FFFFFF",
  "statusBg": "#0969DA",
  "selectedBg": "#DDF4FF",
  "selectionFg": "#1F2328",
  "currentLine": "#1F2328",
  "currentLineBg": "#F6F8FA",
  "surfaceFg": "#1F2328",
  "surfaceBg": "#FFFFFF",
  "chromeFg": "#6E7781",
  "chromeBg": "#F6F8FA",
  "promptFg": "#1F2328",
  "promptBg": "#EAEEF2",
  "lineNumberFg": "#8C959F",
  "lineNumberBg": "#FFFFFF",
  "activeLineFg": "#1F2328",
  "activeLineBg": "#F6F8FA",
  "syntax": {
    "keyword": "#CF222E",
    "keywordControl": "#CF222E",
    "keywordOperator": "#CF222E",
    "string": "#0A3069",
    "stringSpecial": "#0A3069",
    "number": "#0550AE",
    "comment": "#6E7781",
    "function": "#8250DF",
    "functionCall": "#8250DF",
    "type": "#953800",
    "constructor": "#953800",
    "attribute": "#0550AE"
  }
}
