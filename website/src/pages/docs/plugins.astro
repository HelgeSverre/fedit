---
import DocsLayout from "../../layouts/DocsLayout.astro";
import TuiFrame from "../../components/TuiFrame.astro";

const actions = [
  {
    name: "Notify",
    arg: "Severity * string",
    use: "Report a result; no buffer change.",
    sample: `[ Notify(Info, $"{n} words") ]`,
  },
  {
    name: "InsertText",
    arg: "string",
    use: "Add text at the cursor — timestamps, snippets, UUIDs.",
    sample: `[ InsertText "[\\(stamp)\\] " ]`,
  },
  {
    name: "ReplaceSelection",
    arg: "string",
    use: "Replace selected text (inserts if no selection).",
    sample: `[ ReplaceSelection "kebab-cased" ]`,
  },
  {
    name: "MoveCursor",
    arg: "{ Line; Column }",
    use: "Jump the cursor to a 1-based position.",
    sample: `[ MoveCursor { Line = 42; Column = 7 } ]`,
  },
  {
    name: "OpenFile",
    arg: "string",
    use: "Open a file relative to the workspace root.",
    sample: `[ OpenFile "src/Main.fs" ]`,
  },
  {
    name: "SaveActiveBuffer",
    arg: "—",
    use: "Trigger the same save path as :write.",
    sample: `[ SaveActiveBuffer ]`,
  },
  {
    name: "RunCommand",
    arg: "string",
    use: "Chain into a built-in command by name.",
    sample: `[ RunCommand "open foo.fs" ]`,
  },
  {
    name: "SetClipboard",
    arg: "string",
    use: "Copy text to the system clipboard.",
    sample: `[ SetClipboard buffer.Text ]`,
  },
  {
    name: "SelectRange",
    arg: "CursorPosition * CursorPosition",
    use: "Select between two positions — the anchor pins one end, the caret lands on the cursor, like a shift+motion selection.",
    sample: `[ SelectRange(anchor, cursor) ]`,
  },
  {
    name: "OpenFilePreview",
    arg: "string",
    use: "Open a file into the preview slot — the sidebar's Space behavior. Already-open files are activated instead.",
    sample: `[ OpenFilePreview "docs/plan.md" ]`,
  },
  {
    name: "RevealPath",
    arg: "string",
    use: "Expand and select a path in the sidebar without stealing focus. Paths outside the workspace are a no-op.",
    sample: `[ RevealPath "src/Main.fs" ]`,
  },
  {
    name: "ReplaceRange",
    arg: "CursorPosition * CursorPosition * string",
    use: "Replace the span between two 1-based positions as one undo entry. Ends swap if reversed; coordinates clamp.",
    sample: `[ ReplaceRange(from, to_, "text") ]`,
  },
  {
    name: "ClearSelection",
    arg: "—",
    use: "Collapse the selection to a caret. No-op without a selection.",
    sample: `[ ClearSelection ]`,
  },
  {
    name: "DeleteSelection",
    arg: "—",
    use: "Delete the selected text as one undo entry. No-op without a selection.",
    sample: `[ DeleteSelection ]`,
  },
  {
    name: "SwitchBuffer",
    arg: "int",
    use: "Activate a buffer by its BufferView.Id. Unknown ids raise an error notification.",
    sample: `[ SwitchBuffer buffer.Id ]`,
  },
  {
    name: "NewBuffer",
    arg: "string * string",
    use: "Create a scratch buffer holding text and make it active. Later actions in the list target it.",
    sample: `[ NewBuffer("todos", report) ]`,
  },
  {
    name: "SetBufferActivation",
    arg: "string",
    use: "Run a registered command when a line of the active buffer is activated (Enter or left-click). Place it after the NewBuffer it targets.",
    sample: `[ SetBufferActivation "todo-jump" ]`,
  },
  {
    name: "OpenFileAt",
    arg: "string * { Line; Column } * bool",
    use: "Open a file and move the cursor to a 1-based position once it loads; the target survives the async open and applies if the file is already open. preview picks the preview slot.",
    sample: `[ OpenFileAt(path, { Line = 42; Column = 7 }, false) ]`,
  },
];

const lifecycle = [
  {
    stage: "SCAN",
    file: "Plugins.discover",
    desc: "List every <name>/ under ~/.config/fedit/plugins/ and parse its plugin.json.",
  },
  {
    stage: "BUILD",
    file: "Plugins.build",
    desc: "If the DLL is missing or older than any .fs, run dotnet build -c Release.",
  },
  {
    stage: "LOAD",
    file: "AssemblyLoadContext",
    desc: "Each plugin gets its own ALC so it can't poison the host's type identity.",
  },
  {
    stage: "REGISTER",
    file: "register(collector)",
    desc: "Call the plugin's entry point with a collector implementing IPluginHost.",
  },
];

const examples = [
  {
    name: "wordcount",
    command: ":wc",
    blurb: "Count words in the active buffer.",
    uses: "Notify",
  },
  {
    name: "journal",
    command: ":journal",
    blurb: "Insert a [YYYY-MM-DD HH:MM] stamp at the cursor; the sidebar follows the stamped file.",
    uses: "InsertText + RevealPath + Notify",
  },
  {
    name: "todo-count",
    command: ":todocount",
    blurb: "Walk the workspace, count lines containing TODO:.",
    uses: "Notify",
  },
  {
    name: "todo-list",
    command: ":todolist",
    blurb:
      "List every TODO: as path:line in a clickable todos buffer; Enter or click jumps to the source (cap 50).",
    uses: "NewBuffer + SetBufferActivation + OpenFileAt + Notify",
  },
  {
    name: "todo-next",
    command: ":todonext",
    blurb: "Jump cursor to the next TODO:; wraps, then continues into other open buffers.",
    uses: "MoveCursor + SwitchBuffer + RegisterKeybinding",
  },
  {
    name: "jot",
    command: ":jot",
    blurb: "Session scratchpad: jot code locations, check them off, jump back.",
    uses: "NewBuffer + SwitchBuffer + ReplaceRange + RevealPath + OpenFilePreview",
  },
];

const verbs = [
  { v: "list", arg: "", desc: "Show plugins with status (ok / disabled / FAIL)." },
  { v: "enable", arg: "<name>", desc: "Re-enable a disabled plugin; persists to config." },
  {
    v: "disable",
    arg: "<name>",
    desc: "Disable a plugin without removing it; persists to config.",
  },
  { v: "install", arg: "<url-or-path>", desc: "Folder, git URL, or .zip — auto-detected." },
  { v: "remove", arg: "<name>", desc: "Delete the plugin folder and rescan." },
  { v: "reload", arg: "", desc: "Rescan disk; rebuilds anything stale." },
  {
    v: "validate",
    arg: "<path>",
    desc: "Dry-run: parse the manifest, report what would register.",
  },
];
---

<DocsLayout
  title="plugins"
  description="Build fedit plugins in F#. A five-minute quickstart, the eighteen PluginAction types you can return, and six reference implementations under examples/."
  image="/og/extend.png"
>
  <div class="section__head">
    <h1>plugins</h1>
    <p class="section__lede">
      Plugins register commands and keybindings in F#. They live in <code
        >~/.config/fedit/plugins/</code
      >, build lazily on first launch, and run in-process against a read-only snapshot of the
      workspace. No JSON manifests beyond the bare minimum, no IPC, no schema — just a function.
    </p>
  </div>

  <section>
    <p class="doc-p note">
      <strong>Trust model.</strong> Plugins are full .NET code with no sandbox. They can read any file,
      open any socket, and run any process. Treat installation like installing a shell tool — only run
      plugins from sources you trust.
    </p>
  </section>

  <section>
    <h2>quick start</h2>
    <p class="doc-p">From zero to running plugin in three commands and three keystrokes.</p>

    <ol class="doc-steps">
      <li>
        <strong>Drop a plugin into the plugins directory.</strong>
        <pre class="block"
          ><span class="dim">$</span> mkdir -p ~/.config/fedit/plugins
<span class="dim">$</span> cp -R examples/wordcount ~/.config/fedit/plugins/
<span class="dim">$</span> ./fedit .</pre
        >
        <p class="doc-p">
          On launch the host scans this directory, compiles anything stale via
          <code>dotnet build -c Release</code>, and caches the resulting DLL alongside the source.
        </p>
      </li>
      <li>
        <strong>Confirm it loaded.</strong>
        <p class="doc-p">
          The plugin already built and loaded on launch. To check: <kbd>Ctrl+P</kbd> → type
          <code>plugin list</code>. The dock shows each plugin's status and surfaces any build
          failures with the exact compiler output. Edited a plugin since launch?
          <code>plugin reload</code> rebuilds anything stale and reloads.
        </p>
      </li>
      <li>
        <strong>Run your plugin's command.</strong>
        <p class="doc-p">
          Type <code>wc</code> and hit <kbd>Enter</kbd>. The active buffer's word count appears in
          the notification dock. That's it.
        </p>
      </li>
    </ol>
  </section>

  <section>
    <h2>anatomy of a plugin</h2>
    <p class="doc-p">
      The whole authoring surface fits in one short file. The numbered callouts below point to each
      piece's role.
    </p>

    <TuiFrame label="examples/wordcount/Plugin.fs"
      ><Fragment
        set:html={`<span class="muted">namespace</span> Wordcount                                  <span class="accent">1</span>

<span class="muted">open</span> Fedit.PluginApi                              <span class="accent">2</span>

<span class="muted">module</span> Plugin =                                    <span class="accent">3</span>
    <span class="muted">let</span> register (host: IPluginHost) =              <span class="accent">4</span>
        host.RegisterCommand
            { Name = <span class="accent">"wc"</span>                              <span class="accent">5</span>
              Usage = <span class="accent">"wc"</span>
              Summary = <span class="accent">"Count words..."</span>
              Run = <span class="muted">fun</span> ctx -&gt;                       <span class="accent">6</span>
                  <span class="muted">let</span> n = ctx.ActiveBuffer.Text.Split(...).Length
                  [ Notify(Info, <span class="accent">$"{n} words"</span>) ] }            <span class="accent">7</span>`}
      /></TuiFrame
    >

    <ol class="doc-notes">
      <li>
        <strong>Namespace.</strong> Becomes the prefix in <code>entryType</code>. Matches
        <code>plugin.json</code>'s <code>"entryType": "Wordcount.Plugin"</code>.
      </li>
      <li>
        <strong>Open the contract.</strong> All API types live in <code>Fedit.PluginApi</code>.
        Single import — no transitive editor types leak.
      </li>
      <li>
        <strong>Entry module.</strong> The host loads this module by name from the manifest.
      </li>
      <li>
        <strong>register.</strong> Called once at plugin load. Synchronous; must not throw. Exceptions
        mark the plugin as <code>Failed</code> and the host continues.
      </li>
      <li>
        <strong>Command name.</strong> Users invoke as <code>:wc</code>. Tab-completes alongside
        built-ins. Collisions with built-ins drop the plugin's command.
      </li>
      <li>
        <strong>Handler.</strong> Runs each invocation with a fresh <code>PluginContext</code> snapshot
        — active buffer text, cursor, all open buffers, workspace root. Never live state.
      </li>
      <li>
        <strong>Return value.</strong> A <code>PluginAction list</code>. The host translates each
        action into a core editor effect (notification, buffer mutation, file open, …).
      </li>
    </ol>
  </section>

  <section>
    <h2>lifecycle</h2>
    <p class="doc-p">
      What happens between <code>./fedit .</code> and your <code>register</code> function getting called.
      Runs automatically on startup, and on demand via <code>:plugin reload</code>.
    </p>

    <ol class="doc-pipeline">
      {
        lifecycle.map((stage, i) => (
          <li>
            <code class="pipeline-step">
              {String(i + 1).padStart(2, "0")} {stage.stage}
            </code>
            <code class="pipeline-ref">{stage.file}</code>
            <p class="doc-p">{stage.desc}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <section>
    <h2>actions</h2>
    <p class="doc-p">
      A plugin's <code>Run</code> function returns a list of these. The host applies them in order — pick
      the right one for the effect you want.
    </p>

    <dl class="doc-dl">
      {
        actions.map((a) => (
          <div class="doc-dl__row">
            <dt>
              <code class="dl-name">{a.name}</code>
              <span class="dl-arg">{a.arg}</span>
            </dt>
            <dd>
              <p class="doc-p">{a.use}</p>
              <pre class="inline-sample">{a.sample}</pre>
            </dd>
          </div>
        ))
      }
    </dl>
  </section>

  <section>
    <h2>six reference plugins</h2>
    <p class="doc-p">
      Each demonstrates a different combination of actions. Source under <code>examples/</code> — copy
      any folder to <code>~/.config/fedit/plugins/</code> and it'll build on the next launch.
    </p>

    <dl class="doc-dl">
      {
        examples.map((ex) => (
          <div class="doc-dl__row">
            <dt>
              <code class="dl-name">{ex.command}</code>
              <span class="dl-arg">{ex.name}</span>
            </dt>
            <dd>
              <p class="doc-p">{ex.blurb}</p>
              <p class="example-uses">
                uses <span class="accent-word">{ex.uses}</span> ·{" "}
                <a
                  href={`https://github.com/HelgeSverre/fedit/tree/main/examples/${ex.name}`}
                  target="_blank"
                  rel="noopener"
                >
                  source →
                </a>
              </p>
            </dd>
          </div>
        ))
      }
    </dl>
  </section>

  <section>
    <h2>the :plugin command</h2>
    <p class="doc-p">
      One built-in command with verb dispatch. Tab completion suggests verbs first, then arguments.
    </p>

    <dl class="doc-dl">
      {
        verbs.map((v) => (
          <div class="doc-dl__row">
            <dt>
              <code class="dl-name">
                :plugin {v.v}
                {v.arg ? ` ${v.arg}` : ""}
              </code>
            </dt>
            <dd>
              <p class="doc-p">{v.desc}</p>
            </dd>
          </div>
        ))
      }
    </dl>
  </section>

  <section>
    <h2>further reading</h2>
    <ul class="doc-links">
      <li>
        <a href="https://github.com/HelgeSverre/fedit/blob/main/docs/plugins.md">docs/plugins.md</a> —
        the author guide: manifest reference, every type, conflict policy, debugging, distribution.
      </li>
      <li>
        <a href="https://github.com/HelgeSverre/fedit/tree/main/examples">examples/</a> — six plugins
        from 16 to ~100 lines. Copy any one as your starting skeleton; all MIT-licensed.
      </li>
      <li>
        <a href="https://github.com/HelgeSverre/fedit/tree/main/src/Fedit.PluginApi"
          >src/Fedit.PluginApi/</a
        > — the contract itself. Two short files; read it in five minutes.
      </li>
    </ul>
  </section>
</DocsLayout>

<style>
  .doc-p {
    color: var(--fg);
    max-width: 75ch;
  }
  .doc-p code {
    color: var(--fg);
  }

  .note {
    border-left: 3px solid var(--accent);
    padding: var(--space-2) var(--space-3);
    background: var(--surface-2);
  }
  .note strong {
    color: var(--accent);
  }

  .accent-word {
    color: var(--accent);
  }

  /* Quick-start ordered steps + anatomy notes */
  .doc-steps,
  .doc-notes {
    padding-left: 1.4em;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 75ch;
  }
  .doc-steps li,
  .doc-notes li {
    color: var(--fg);
    line-height: 1.55;
  }
  .doc-notes strong,
  .doc-steps strong {
    color: var(--fg);
  }

  pre.block {
    max-width: 75ch;
    margin: var(--space-2) 0;
  }

  /* Lifecycle pipeline as a stacked list */
  .doc-pipeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: 75ch;
  }
  .doc-pipeline li {
    border-left: 2px solid var(--border);
    padding: var(--space-1) 0 var(--space-1) var(--space-3);
  }
  .pipeline-step {
    background: transparent;
    border: none;
    padding: 0;
    color: var(--accent);
    font-size: 12px;
    letter-spacing: 0.08em;
  }
  .pipeline-ref {
    background: transparent;
    border: none;
    padding: 0 0 0 var(--space-2);
    color: var(--fg-subtle);
    font-size: 12px;
  }
  .doc-pipeline p {
    margin: var(--space-1) 0 0;
  }

  /* Definition-list reference grid (actions, examples, verbs) */
