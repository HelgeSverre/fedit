---
import Site from "../layouts/Site.astro";
import Symbol from "../components/Symbol.astro";
import ThemeCard from "../components/ThemeCard.astro";
import { themes } from "../data/themes";

const neutrals = [
  { name: "neutral-50", hex: "#FAFAFA", ansi: 231 },
  { name: "neutral-100", hex: "#F4F4F5", ansi: 255 },
  { name: "neutral-200", hex: "#E7E7EA", ansi: 253 },
  { name: "neutral-300", hex: "#D3D3D8", ansi: 251 },
  { name: "neutral-400", hex: "#A6A6AD", ansi: 247 },
  { name: "neutral-500", hex: "#787880", ansi: 243 },
  { name: "neutral-600", hex: "#58585F", ansi: 240 },
  { name: "neutral-700", hex: "#3F3F46", ansi: 238 },
  { name: "neutral-800", hex: "#27272A", ansi: 235 },
  { name: "neutral-900", hex: "#18181B", ansi: 233 },
  { name: "neutral-950", hex: "#0B0B0D", ansi: 232 },
];

const accentScale = [
  { name: "accent-100", hex: "#D1FAE5", ansi: 195 },
  { name: "accent-300", hex: "#6EE7B7", ansi: 121 },
  { name: "accent-500", hex: "#00B86B", ansi: 35, source: true },
  { name: "accent-700", hex: "#047857", ansi: 29 },
  { name: "accent-900", hex: "#064E3B", ansi: 22 },
];

const voiceRules = [
  {
    rule: "Lead with the verb.",
    ex: "Edits files in the terminal.",
    bad: "A small terminal text editor that lets you edit files.",
  },
  {
    rule: "No marketing adjectives. Numbers or nothing.",
    ex: "Opens a 200MB log file in under 80ms.",
    bad: "Blazing fast, even for huge files.",
  },
  {
    rule: 'You, never "users" or "developers".',
    ex: "Open a workspace with fedit .",
    bad: "Users can open a workspace by running fedit .",
  },
  {
    rule: "Show, don't say.",
    ex: "Run fedit . and the workspace appears as a file tree.",
    bad: "fedit provides an intuitive workspace view.",
  },
  {
    rule: "No emoji. One em-dash per paragraph, max.",
    ex: "Edits files in the terminal. Written in F#.",
    bad: "✨ The next-generation editor — for the terminal — built — for you.",
  },
];

const dontList = [
  "Purple or blue gradient backgrounds",
  "Glassmorphism cards (backdrop-blur)",
  "Centered hero with 3 feature cards under it",
  '"Trusted by" logo strip',
  "Sparkles, meteors, animated background lines",
  '"Powered by AI" badge',
  "Emoji in copy or commit messages",
  "Inter font for anything",
  '"Build the future of X", "Your all-in-one platform"',
];
---

<Site
  title="brand"
  description="The fedit brand: caret mark, Departure Mono + JetBrains Mono, phosphor green accent, seven editor themes, voice rules."
  image="/og/brand.png"
>
  <!-- ============================================================ -->
  <!-- HERO                                                         -->
  <!-- ============================================================ -->
  <section class="section brand-hero">
    <div class="container">
      <p class="eyebrow">brand · v1</p>
      <h1>The Mark, the Color, the Voice.</h1>
      <p class="brand-lede">
        A formula-driven identity. <span class="accent-word">One symbol</span>, <span
          class="accent-word">one workhorse mono</span
        >, <span class="accent-word">one accent</span>, a consistent lockup. Five inputs, seven
        artifact files. No subscriptions, no AI buzzwords, no purple gradients.
      </p>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- THE MARK                                                     -->
  <!-- ============================================================ -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__head">
        <h2>the mark</h2>
        <p class="section__lede">
          The caret. Echoes the editor's cursor, the upward chevron in the status bar, the visual
          rhythm of the wordmark. Renders cleanly at 16px, collapses to a single ANSI glyph for
          terminal banners.
        </p>
      </div>

      <div class="mark-row">
        <div class="mark-cell">
          <Symbol size={128} color="var(--accent)" strokeWidth={2.5} />
          <span>128 px</span>
        </div>
        <div class="mark-cell">
          <Symbol size={64} color="var(--accent)" strokeWidth={2.5} />
          <span>64 px</span>
        </div>
        <div class="mark-cell">
          <Symbol size={32} color="var(--accent)" strokeWidth={3} />
          <span>32 px</span>
        </div>
        <div class="mark-cell">
          <Symbol size={16} color="var(--accent)" strokeWidth={4} />
          <span>16 px</span>
        </div>
        <div class="mark-cell mono">
          <Symbol size={64} color="currentColor" strokeWidth={2.5} />
          <span>mono · currentColor</span>
        </div>
      </div>

      <div class="downloads">
        <a href="/symbol.svg" download>symbol.svg</a>
        <a href="/symbol-mono.svg" download>symbol-mono.svg</a>
        <a href="/favicon.svg" download>favicon.svg</a>
      </div>

      <h3>lockup</h3>
      <div class="lockup">
        <Symbol size={56} color="var(--accent)" strokeWidth={3} />
        <span class="lockup-word">fedit</span>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- COLOR                                                        -->
  <!-- ============================================================ -->
  <section class="section">
    <div class="container">
      <div class="section__head">
        <h2>color</h2>
        <p class="section__lede">
          11-step cool-gray neutral scale + 5-step phosphor-green accent scale. Contrast warning:
          green fails 4.5:1 against white, so text on accent surfaces uses neutral-900, not
          neutral-50.
        </p>
      </div>

      <h3>neutrals · cool gray, hue 250</h3>
      <div class="swatch-row">
        {
          neutrals.map((c) => (
            <div class="swatch" style={`--c:${c.hex};`}>
              <span class="chip" style={`background:${c.hex};`} />
              <span class="swatch-name">{c.name}</span>
              <span class="swatch-meta">
                {c.hex} · ansi {c.ansi}
              </span>
            </div>
          ))
        }
      </div>

      <h3>accent · phosphor green</h3>
      <div class="swatch-row">
        {
          accentScale.map((c) => (
            <div class={`swatch ${c.source ? "is-source" : ""}`} style={`--c:${c.hex};`}>
              <span class="chip" style={`background:${c.hex};`} />
              <span class="swatch-name">
                {c.name}
                {c.source && <em> · source</em>}
              </span>
              <span class="swatch-meta">
                {c.hex} · ansi {c.ansi}
              </span>
            </div>
          ))
        }
      </div>

      <h3>semantic tokens</h3>
      <dl class="dl-grid token-grid">
        <dt><code>--bg</code></dt>
        <dd>page background</dd>
        <dt><code>--surface-1</code> / <code>--surface-2</code></dt>
        <dd>alternating section backgrounds</dd>
        <dt><code>--fg</code></dt>
        <dd>primary text</dd>
        <dt><code>--fg-muted</code></dt>
        <dd>secondary text, descriptions</dd>
        <dt><code>--fg-subtle</code></dt>
        <dd>hints, captions, line numbers</dd>
        <dt><code>--border</code></dt>
        <dd>pane dividers, swatch chips</dd>
        <dt><code>--accent</code></dt>
        <dd>the one accent moment</dd>
        <dt><code>--accent-fg</code></dt>
        <dd>text on accent surfaces (neutral-900, not white)</dd>
        <dt><code>--accent-soft</code></dt>
        <dd>focus rings, hover hints — 25% accent</dd>
      </dl>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- TYPOGRAPHY                                                   -->
  <!-- ============================================================ -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__head">
        <h2>typography</h2>
        <p class="section__lede">
          Two fonts, one job each. Departure Mono carries the brand at heading sizes. JetBrains Mono
          carries body, code, and CLI fallback.
        </p>
      </div>

      <div class="type-card">
        <header>
          <span class="type-name">Departure Mono</span>
          <span class="type-role">brand · headings · wordmark</span>
        </header>
        <div class="type-sample dep">
          <p class="dep-4xl">fedit</p>
          <p class="dep-2xl">Edit files in the terminal.</p>
          <p class="dep-lg">Small. Written in F#.</p>
        </div>
        <footer>
          <code>departuremono.com</code>
          <span>OFL · pixel-tuned · retro-CRT character</span>
        </footer>
      </div>

      <div class="type-card">
        <header>
          <span class="type-name">JetBrains Mono</span>
          <span class="type-role">body · code · CLI fallback</span>
        </header>
        <div class="type-sample jb">
          <p class="jb-lg">Opens a workspace, shows a file tree, edits files, saves to disk.</p>
          <p class="jb-base">
            Multi-buffer, undo/redo, find, command palette, system clipboard. Seven color themes.
            Persists the last 20 opened files and your theme across sessions.
          </p>
          <pre
            class="block jb-code"><span class="dim">$</span> fedit src/Main.fs
<span class="muted">opened</span> <span class="accent">src/Main.fs</span> <span class="muted">· 312 lines</span></pre>
        </div>
        <footer>
          <code>jetbrains.com/lp/mono</code>
          <span>OFL · humanist mono · screen-tuned</span>
        </footer>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- VOICE                                                        -->
  <!-- ============================================================ -->
  <section class="section">
    <div class="container">
      <div class="section__head">
        <h2>voice</h2>
        <p class="section__lede">
          Five rules. They apply to README, landing page, CLI help, error messages, release notes,
          and commit messages.
        </p>
      </div>

      <ol class="voice-list">
        {
          voiceRules.map((v, i) => (
            <li>
              <div class="voice-num">0{i + 1}</div>
              <div class="voice-body">
                <p class="voice-rule">{v.rule}</p>
                <p class="voice-good">
                  <span class="tag tag-good">good</span>
                  {v.ex}
                </p>
                <p class="voice-bad">
                  <span class="tag tag-bad">avoid</span>
                  {v.bad}
                </p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- DO / DON'T                                                   -->
  <!-- ============================================================ -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__head">
        <h2>don't</h2>
        <p class="section__lede">
          Refusing the AI median is the brand's identity. The 2026 baseline of vibe-coded UI is what
          this list rejects on sight.
        </p>
      </div>

      <ul class="dont-list">
        {
          dontList.map((d) => (
            <li>
              <span class="x" aria-hidden="true">
                ✕
              </span>
              {d}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- THEMES                                                       -->
  <!-- ============================================================ -->
  <section class="section">
    <div class="container">
      <div class="section__head">
        <h2>themes</h2>
        <p class="section__lede">
          Seven user-selectable accent palettes. Each shares the same neutral chrome; only five
          slots swap (dock title, status bar, selection highlight, current-line gutter, cursor).
          Spec in <code>brand/themes/*.json</code>, implementation in <code
            >src/Fedit/Themes.fs</code
          >.
        </p>
      </div>
      <div class="theme-grid">
        {themes.map((theme) => <ThemeCard theme={theme} />)}
      </div>
    </div>
  </section>
</Site>

<style>
  .brand-hero {
    padding: 96px 0 64px;
    border-top: none;
  }
  .brand-hero h1 {
    max-width: 18ch;
    margin-bottom: 24px;
  }
  .brand-hero .eyebrow {
    font-family: "JetBrains Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 20px;
  }
  .brand-lede {
    font-family: "Departure Mono", "JetBrains Mono", monospace;
    font-size: clamp(18px, 2.5vw, 22px);
    line-height: 1.45;
    max-width: 48ch;
    margin: 0;
  }
  .accent-word {
    color: var(--accent);
  }

  /* THE MARK */
  .mark-row {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    align-items: flex-end;
    padding: 32px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }
  .mark-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 16px;
    background: var(--surface-deep);
    border: 1px solid var(--border);
    border-radius: 4px;
    min-width: 80px;
    transition: border-color var(--t-base) var(--ease);
  }
  .mark-cell:hover {
    border-color: var(--accent-soft);
  }
  .mark-cell span {
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }
  .mark-cell.mono {
    margin-left: auto;
  }
  .downloads {
    margin: 16px 0 32px;
    display: flex;
    gap: 14px;
    font-size: 12px;
    color: var(--fg-muted);
  }
  .downloads a {
    text-decoration-color: var(--accent-soft);
  }
  .lockup {
    display: inline-flex;
    align-items: center;
    gap: 16px;
    padding: 20px 24px;
    background: var(--surface-deep);
    border: 1px solid var(--border);
    border-radius: 4px;
  }
  .lockup-word {
    font-family: "Departure Mono", "JetBrains Mono", monospace;
    font-size: 56px;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  /* COLOR */
  .swatch-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 12px;
    margin-bottom: 28px;
  }
  .swatch {
    display: grid;
    grid-template-rows: auto auto auto;
    gap: 4px;
    padding: 10px 12px;
    background: var(--surface-deep);
    border: 1px solid var(--border);
    border-radius: 4px;
    transition: border-color var(--t-base) var(--ease);
  }
  .swatch.is-source {
    border-color: var(--accent);
  }
  .swatch:hover {
    border-color: var(--accent-soft);
  }
  .chip {
    display: block;
    height: 40px;
    border: 1px solid var(--border);
    border-radius: 2px;
    margin-bottom: 6px;
  }
  .swatch-name {
    font-family: "Departure Mono", "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--fg);
  }
  .swatch-name em {
    color: var(--accent);
    font-style: normal;
  }
  .swatch-meta {
    font-size: 11px;
    color: var(--fg-subtle);
  }
  .token-grid dt {
    font-family: "JetBrains Mono", monospace;
  }
  .token-grid dt code {
    font-size: 12px;
  }

  /* TYPOGRAPHY */
  .type-card {
    background: var(--surface-deep);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 24px;
    margin-bottom: 16px;
    transition: border-color var(--t-base) var(--ease);
  }
  .type-card:hover {
    border-color: var(--accent-soft);
  }
  .type-card header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }
  .type-name {
    font-family: "Departure Mono", "JetBrains Mono", monospace;
    font-size: 18px;
    letter-spacing: -0.01em;
    color: var(--fg);
  }
  .type-role {
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-subtle);
  }
  .type-sample p {
    margin: 0;
  }
  .type-sample.dep p {
    font-family: "Departure Mono", monospace;
    color: var(--fg);
  }
  .dep-4xl {
    font-size: clamp(48px, 8vw, 64px);
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .dep-2xl {
    font-size: 24px;
    letter-spacing: -0.02em;
    line-height: 1.2;
    margin-top: 16px !important;
  }
  .dep-lg {
    font-size: 18px;
    color: var(--fg-muted) !important;
    margin-top: 8px !important;
  }

  .type-sample.jb p {
    font-family: "JetBrains Mono", monospace;
  }
  .jb-lg {
    font-size: 18px;
    color: var(--fg);
    line-height: 1.5;
  }
  .jb-base {
    font-size: 14px;
    color: var(--fg-muted);
    line-height: 1.6;
    margin-top: 12px !important;
    max-width: 65ch;
  }
  .jb-code {
    margin-top: 16px;
  }

  .type-card footer {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
    font-size: 11px;
    color: var(--fg-subtle);
  }
  .type-card footer code {
    background: transparent;
    border: none;
    padding: 0;
    color: var(--fg-muted);
    font-size: 11px;
  }

  /* VOICE */
  .voice-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 16px;
  }
  .voice-list li {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 16px;
    padding: 20px;
    background: var(--surface-deep);
    border: 1px solid var(--border);
    border-radius: 4px;
    transition: border-color var(--t-base) var(--ease);
  }
  .voice-list li:hover {
    border-color: var(--accent-soft);
  }
  .voice-num {
    font-family: "Departure Mono", monospace;
    font-size: 28px;
    color: var(--accent);
    line-height: 1;
  }
  .voice-rule {
    font-family: "Departure Mono", "JetBrains Mono", monospace;
    font-size: 18px;
    color: var(--fg);
    margin: 0 0 12px;
  }
  .voice-good,
  .voice-bad {
    font-size: 13px;
    margin: 6px 0;
    color: var(--fg);
    line-height: 1.5;
  }
  .voice-bad {
    color: var(--fg-muted);
  }
  .tag {
    display: inline-block;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: 2px;
    margin-right: 10px;
  }
  .tag-good {
    background: color-mix(in oklch, var(--accent) 18%, transparent);
    color: var(--accent);
  }
  .tag-bad {
    background: var(--surface-2);
    color: var(--fg-subtle);
    border: 1px solid var(--border);
  }

  /* DON'T */
  .dont-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 6px;
  }
  .dont-list li {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding: 12px 14px;
    background: var(--surface-deep);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--fg-muted);
    font-size: 13px;
  }
  .dont-list .x {
    color: var(--accent);
    font-weight: 700;
    font-size: 14px;
  }

  /* THEMES */
  .theme-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
  }

  pre.block {
    max-width: 100%;
  }
</style>
