---
import Site from "../layouts/Site.astro";
import Symbol from "../components/Symbol.astro";
import CaretRise from "../components/mascots/CaretRise.astro";

const features = [
  {
    name: "workspace tree",
    desc: "open a directory, navigate with arrow keys, expand and collapse with left/right",
  },
  { name: "multi-buffer", desc: "open any number of files; switch with next / prev / buffers" },
  {
    name: "piece-table buffers",
    desc: "inserts and deletes stay local; each buffer has its own undo/redo stack",
  },
  { name: "find", desc: "live-highlight as you type; enter or down to advance, up for previous" },
  {
    name: "command palette",
    desc: "Ctrl+P opens a command bar — prefix-matched commands, substring-matched files, last 20 entries as history",
  },
  {
    name: "system clipboard",
    desc: "Ctrl+C / Ctrl+X / Ctrl+V via pbcopy on macOS, xclip on Linux",
  },
  {
    name: "live file watcher",
    desc: "external changes trigger a debounced 300ms rescan; no need to press Ctrl+R",
  },
  {
    name: "thirteen themes",
    desc: "full-surface palettes (incl. light); swap live, persists to ~/.config/fedit/config.json",
  },
  { name: "UTF-8", desc: "reads any line-ending style, preserves it on save, no BOM written" },
];

const cards = [
  {
    href: "/commands",
    title: "commands",
    blurb: "Every keybinding and command bar verb in one reference.",
  },
  {
    href: "/themes",
    title: "themes",
    blurb: "Thirteen palettes, including light. Switch live from the command bar.",
  },
  {
    href: "/how",
    title: "how it works",
    blurb: "Pure-data MVU loop, piece-table buffers, effects on the thread pool.",
  },
  {
    href: "/brand",
    title: "brand",
    blurb: "Caret, Departure Mono, phosphor green. The voice rules and the do-not list.",
  },
];
---

<Site
  title="fedit — edit files in the terminal"
  description="A small terminal text editor written in F#. Workspace tree, multi-buffer, piece-table buffers, find, command palette, system clipboard, thirteen color themes."
  image="/og/index.png"
  titleOverride
>
  <!-- ============================================================ -->
  <!-- HERO                                                         -->
  <!-- ============================================================ -->
  <section class="section hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-text">
          <div class="hero-brand">
            <Symbol size={56} color="var(--accent)" strokeWidth={3} class="hero-mark" />
            <h1>fedit</h1>
          </div>
          <p class="hero-lede">
            Edit files in the terminal. Small. Written in <span class="hero-key">F#</span>.
          </p>
          <p class="hero-actions">
            <a href="#install" class="cta-primary">Install fedit</a>
            <a
              href="https://github.com/HelgeSverre/fedit"
              class="cta-secondary"
              target="_blank"
              rel="noopener">View on GitHub</a
            >
          </p>
          <p class="caveat"
            >For macOS &amp; Linux via Homebrew. Windows binary on GitHub Releases.</p
          >
        </div>
        <div class="hero-mascot">
          <CaretRise />
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- WHAT                                                         -->
  <!-- ============================================================ -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__head">
        <h2>what</h2>
      </div>
      <div class="feature-grid">
        {
          features.map((f) => (
            <article class="feature">
              <h3>{f.name}</h3>
              <p>{f.desc}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- INSTALL                                                      -->
  <!-- ============================================================ -->
  <section id="install" class="section">
    <div class="container">
      <div class="section__head"><h2>install</h2></div>

      <h3>homebrew <span class="muted">(macOS &amp; Linux)</span></h3>
      <pre><span class="dim">$</span> brew install helgesverre/tap/fedit</pre>
      <p class="muted-p">
        Auto-detects your OS and CPU (arm64 / x64). Updates land via <code>brew upgrade fedit</code
        >.
      </p>

      <h3>windows</h3>
      <p class="muted-p">
        Download <code>fedit-x86_64-pc-windows-msvc.zip</code> from
        <a href="https://github.com/HelgeSverre/fedit/releases/latest">the latest release</a>,
        extract, and add the folder to your <code>PATH</code>.
      </p>

      <h3>from source</h3>
      <pre
        ><span class="dim">$</span> git clone https://github.com/HelgeSverre/fedit
<span class="dim">$</span> cd fedit
<span class="dim">$</span> just install
<span class="dim">$</span> fedit .</pre
      >
      <p class="muted-p">
        The <code>just install</code> recipe publishes a self-contained single-file binary to <code
          >~/.local/bin</code
        >. Override the destination with <code>just install path/to/bin</code>. Remove with <code
          >just uninstall</code
        >. Requires .NET SDK 10 and <a href="https://github.com/casey/just">just</a>; the repo ships
        a local <code>.dotnet</code> SDK so cloning is enough.
      </p>

      <h3>run without installing</h3>
      <pre
        ><span class="dim">$</span> ./fedit .                              <span class="comment"># shell shim, pins local .dotnet</span>
<span class="dim">$</span> dotnet run --project src/Fedit/Fedit.fsproj -- .
<span class="dim">$</span> just run .                             <span class="comment"># or via the recipe</span></pre
      >

      <h3>dev loop</h3>
      <pre
        ><span class="dim">$</span> just dev .         <span class="comment"># dotnet watch, re-launches on source changes</span>
<span class="dim">$</span> just check         <span class="comment"># lint + build + test, the pre-commit gate</span>
<span class="dim">$</span> just test          <span class="comment"># xUnit + FsCheck</span>
<span class="dim">$</span> just format        <span class="comment"># fantomas + oxfmt</span></pre
      >

      <h3>flags</h3>
      <dl class="dl-grid">
        <dt><code>--log &lt;path&gt;</code></dt>
        <dd>
          append a UTC-timestamped trace of every <code>Msg</code> and <code>Effect</code> to the file
          — for debugging without polluting the TUI
        </dd>
      </dl>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- READ NEXT                                                    -->
  <!-- ============================================================ -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__head"><h2>read next</h2></div>
      <div class="card-grid">
        {
          cards.map((c) => (
            <a class="card" href={c.href}>
              <h3>{c.title}</h3>
              <p>{c.blurb}</p>
              <span class="card-arrow" aria-hidden="true">
                →
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>
</Site>

<style>
  /* ----- hero ----- */
  .hero {
    padding: var(--space-6) 0;
    background: var(--surface-1);
    border-top: none;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-5);
    align-items: center;
  }
  @media (max-width: 800px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }
  .hero-brand {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }
  .hero h1 {
    font-size: clamp(48px, 9vw, 72px);
    line-height: 1;
  }
  .hero-lede {
    font-family: var(--font-departure-mono);
    font-size: clamp(20px, 3.2vw, 26px);
    line-height: 1.35;
    color: var(--fg);
    margin: 0 0 var(--space-4);
    max-width: 36ch;
  }
  .hero-key {
    color: var(--accent);
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: 0 0 var(--space-3);
  }
  .caveat {
    color: var(--fg-muted);
    font-size: 13px;
    margin: 0;
  }
  .hero-mascot {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  @media (max-width: 800px) {
    .hero-mascot {
      order: -1;
      margin-bottom: var(--space-2);
    }
  }

  /* ----- CTA buttons ----- */
  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-departure-mono);
    font-size: 16px;
    letter-spacing: -0.01em;
    padding: 14px 22px;
    border-radius: 2px;
    text-decoration: none;
    transition:
      transform var(--t-fast) var(--ease),
      background var(--t-fast) var(--ease),
      border-color var(--t-fast) var(--ease),
      color var(--t-fast) var(--ease);
  }
  .cta-primary {
    background: var(--accent);
    color: var(--accent-fg);
    border: 1px solid var(--accent);
  }
  .cta-primary:hover {
    background: var(--accent-700);
    border-color: var(--accent-700);
    color: var(--neutral-50);
    transform: translateY(-1px);
  }
  .cta-primary:active {
    transform: translateY(0);
  }
  .cta-secondary {
    background: transparent;
    color: var(--fg);
    border: 1px solid var(--border-strong);
  }
  .cta-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-1px);
  }
  .cta-secondary:active {
    transform: translateY(0);
  }

  /* ----- what (feature grid) ----- */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-4) var(--space-4);
  }
  .feature {
    padding: 0;
    background: none;
    border: none;
  }
  .feature h3 {
    font-family: var(--font-departure-mono);
    font-size: 14px;
    color: var(--fg);
    text-transform: none;
    letter-spacing: -0.01em;
    margin-top: 0;
  }
  .feature p {
    color: var(--fg-muted);
    font-size: 13px;
    margin-top: var(--space-1);
    line-height: 1.55;
  }

  /* ----- read next cards ----- */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--space-2);
  }
  /* Surface (fill/border/radius/transition + hover border) comes from the
     shared .card base in global.css; these are the home-grid specifics. */
  .card {
    position: relative;
    display: block;
    padding: var(--space-3);
    text-decoration: none;
    color: var(--fg);
  }
  .card:hover {
    transform: translateY(-1px);
  }
  .card h3 {
    font-family: var(--font-departure-mono);
    font-size: 18px;
    margin: 0 0 var(--space-1);
    color: var(--fg);
  }
  .card p {
    color: var(--fg-muted);
    font-size: 13px;
    line-height: 1.55;
    margin: 0;
    max-width: 40ch;
  }
  .card-arrow {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    color: var(--accent);
    transition: transform var(--t-base) var(--ease);
  }
  .card:hover .card-arrow {
    transform: translateX(2px);
  }
</style>
