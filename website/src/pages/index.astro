---
import Site from "../layouts/Site.astro";
import Symbol from "../components/Symbol.astro";
import TuiFrame from "../components/TuiFrame.astro";
import ThemeCard from "../components/ThemeCard.astro";
import TypingMascot from "../components/TypingMascot.astro";
import { themes } from "../data/themes";

const features = [
  {
    name: "workspace tree",
    desc: "open a directory, navigate with arrow keys, expand and collapse with left/right",
  },
  { name: "multi-buffer", desc: "open any number of files; switch with next / prev / buffers" },
  {
    name: "piece-table buffers",
    desc: "inserts and deletes stay local; each buffer has its own undo/redo stack",
  },
  { name: "find", desc: "live-highlight as you type; enter or down to advance, up for previous" },
  {
    name: "command palette",
    desc: "Ctrl+P opens a fuzzy-completing command bar with the last 20 entries as history",
  },
  {
    name: "system clipboard",
    desc: "Ctrl+C / Ctrl+X / Ctrl+V via pbcopy on macOS, xclip on Linux",
  },
  {
    name: "live file watcher",
    desc: "external changes trigger a debounced 300ms rescan; no need to press Ctrl+R",
  },
  {
    name: "seven themes",
    desc: "swap accent palette live; persists to ~/.config/fedit/config.json",
  },
  { name: "UTF-8", desc: "reads any line-ending style, preserves it on save, no BOM written" },
];
---

<Site>
  <!-- ============================================================ -->
  <!-- HERO                                                         -->
  <!-- ============================================================ -->
  <section class="section hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-text">
          <div class="hero-brand">
            <Symbol size={56} color="var(--accent)" strokeWidth={3} class="hero-mark" />
            <h1>fedit</h1>
          </div>
          <p class="hero-lede">
            Edit files in the terminal. Small. Written in <span class="hero-key">F#</span>.
          </p>
          <p class="hero-actions">
            <a href="#install" class="cta-primary">Install fedit</a>
            <a
              href="https://github.com/HelgeSverre/fedit"
              class="cta-secondary"
              target="_blank"
              rel="noopener">View on GitHub</a
            >
          </p>
          <p class="caveat">macOS &amp; Linux via Homebrew. Windows binary on GitHub Releases.</p>
        </div>
        <div class="hero-mascot">
          <TypingMascot />
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- WHAT                                                         -->
  <!-- ============================================================ -->
  <section class="section section--alt">
    <div class="container">
      <div class="section__head">
        <h2>what</h2>
      </div>
      <div class="feature-grid">
        {
          features.map((f) => (
            <article class="feature">
              <h3>{f.name}</h3>
              <p>{f.desc}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- INSTALL                                                      -->
  <!-- ============================================================ -->
  <section id="install" class="section">
    <div class="container">
      <div class="section__head"><h2>install</h2></div>

      <h3>homebrew <span class="muted">(macOS &amp; Linux)</span></h3>
      <pre class="block"><span class="dim">$</span> brew install helgesverre/tap/fedit</pre>
      <p class="muted-p">
        Auto-detects your OS and CPU (arm64 / x64). Updates land via <code>brew upgrade fedit</code
        >.
      </p>

      <h3>windows</h3>
      <p class="muted-p">
        Download <code>fedit-x86_64-pc-windows-msvc.zip</code> from
        <a href="https://github.com/HelgeSverre/fedit/releases/latest">the latest release</a>,
        extract, and add the folder to your <code>PATH</code>.
      </p>

      <h3>from source</h3>
      <pre
        class="block"><span class="dim">$</span> git clone https://github.com/HelgeSverre/fedit
<span class="dim">$</span> cd fedit
<span class="dim">$</span> just install
<span class="dim">$</span> fedit .</pre>
      <p class="muted-p">
        The <code>just install</code> recipe publishes a self-contained single-file binary to <code
          >~/.local/bin</code
        >. Override the destination with <code>just install path/to/bin</code>. Remove with <code
          >just uninstall</code
        >. Requires .NET SDK 9 and <a href="https://github.com/casey/just">just</a>; the repo ships
        a local <code>.dotnet</code> SDK so cloning is enough.
      </p>

      <h3>run without installing</h3>
      <pre
        class="block"><span class="dim">$</span> ./fedit .                              <span class="comment"># shell shim, pins local .dotnet</span>
<span class="dim">$</span> dotnet run --project src/Fedit/Fedit.fsproj -- .
<span class="dim">$</span> just run .                             <span class="comment"># or via the recipe</span></pre>

      <h3>dev loop</h3>
      <pre
        class="block"><span class="dim">$</span> just dev .         <span class="comment"># dotnet watch, re-launches on source changes</span>
<span class="dim">$</span> just check         <span class="comment"># lint + build + test, the pre-commit gate</span>
<span class="dim">$</span> just test          <span class="comment"># xUnit + FsCheck</span>
<span class="dim">$</span> just format        <span class="comment"># fantomas + prettier</span></pre>

      <h3>flags</h3>
      <dl class="dl-grid">
        <dt><code>--log &lt;path&gt;</code></dt>
        <dd>
          append a UTC-timestamped trace of every <code>Msg</code> and <code>Effect</code> to the file
          — for debugging without polluting the TUI
        </dd>
      </dl>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- COMMANDS                                                     -->
  <!-- ============================================================ -->
  <section id="commands" class="section section--alt">
    <div class="container">
      <div class="section__head"><h2>commands</h2></div>

      <h3>global</h3>
      <dl class="dl-grid">
        <dt><kbd>Ctrl+P</kbd></dt>
        <dd>open the command bar</dd>
        <dt><kbd>Ctrl+F</kbd></dt>
        <dd>find in the active buffer</dd>
        <dt><kbd>Ctrl+B</kbd></dt>
        <dd>focus the file tree</dd>
        <dt><kbd>Ctrl+E</kbd></dt>
        <dd>focus the editor</dd>
        <dt><kbd>Ctrl+S</kbd></dt>
        <dd>save the active buffer</dd>
        <dt><kbd>Ctrl+R</kbd></dt>
        <dd>reload the workspace tree</dd>
        <dt><kbd>Ctrl+Q</kbd></dt>
        <dd>quit (prompts once if buffers are dirty; press again to discard)</dd>
        <dt><kbd>Ctrl+Z</kbd></dt>
        <dd>undo</dd>
        <dt><kbd>Ctrl+Y</kbd></dt>
        <dd>redo</dd>
      </dl>

      <h3>editor</h3>
      <dl class="dl-grid">
        <dt><kbd>← → ↑ ↓</kbd></dt>
        <dd>move the cursor</dd>
        <dt><kbd>Home</kbd> · <kbd>End</kbd></dt>
        <dd>jump to line start / end</dd>
        <dt><kbd>PageUp</kbd> · <kbd>PageDown</kbd></dt>
        <dd>scroll a screen at a time</dd>
        <dt><kbd>Alt+←</kbd> · <kbd>Alt+→</kbd></dt>
        <dd>move by word</dd>
        <dt><kbd>Ctrl+Backspace</kbd> · <kbd>Ctrl+Delete</kbd></dt>
        <dd>delete the previous / next word</dd>
        <dt><kbd>Shift+←/→/↑/↓</kbd> · <kbd>Shift+Home</kbd> · <kbd>Shift+End</kbd></dt>
        <dd>extend the selection</dd>
        <dt><kbd>Ctrl+A</kbd></dt>
        <dd>select the whole buffer</dd>
        <dt><kbd>Ctrl+C</kbd> · <kbd>Ctrl+X</kbd></dt>
        <dd>copy / cut to system clipboard</dd>
        <dt><kbd>Ctrl+V</kbd></dt>
        <dd>paste from system clipboard</dd>
        <dt><kbd>Tab</kbd> · <kbd>Shift+Tab</kbd></dt>
        <dd>indent / unindent the current line</dd>
        <dt><kbd>Enter</kbd> · <kbd>Backspace</kbd> · <kbd>Delete</kbd></dt>
        <dd>edit text; with a selection, replace it</dd>
      </dl>

      <h3>find <span class="muted">(after Ctrl+F)</span></h3>
      <dl class="dl-grid">
        <dt>type</dt>
        <dd>extend the query; matches highlight live and the cursor jumps to the first hit</dd>
        <dt><kbd>Enter</kbd> · <kbd>↓</kbd></dt>
        <dd>advance to next match</dd>
        <dt><kbd>↑</kbd></dt>
        <dd>previous match</dd>
        <dt><kbd>Backspace</kbd></dt>
        <dd>shorten query; on empty query, close the prompt</dd>
        <dt><kbd>Escape</kbd></dt>
        <dd>close the prompt and clear the highlights</dd>
      </dl>

      <h3>file tree</h3>
      <dl class="dl-grid">
        <dt><kbd>↑</kbd> · <kbd>↓</kbd></dt>
        <dd>move selection</dd>
        <dt><kbd>PageUp</kbd> · <kbd>PageDown</kbd></dt>
        <dd>jump ten entries at a time</dd>
        <dt><kbd>Home</kbd> · <kbd>End</kbd></dt>
        <dd>first / last visible entry</dd>
        <dt><kbd>←</kbd></dt>
        <dd>collapse the selected directory or move to its parent</dd>
        <dt><kbd>→</kbd></dt>
        <dd>expand the selected directory</dd>
        <dt><kbd>Enter</kbd></dt>
        <dd>open a file or toggle a directory</dd>
        <dt><kbd>Escape</kbd></dt>
        <dd>return focus to the editor</dd>
      </dl>

      <h3>command bar</h3>
      <dl class="dl-grid">
        <dt>type</dt>
        <dd>filter; the dock panel shows matching commands or workspace paths</dd>
        <dt><kbd>Tab</kbd> · <kbd>Shift+Tab</kbd></dt>
        <dd>cycle completions</dd>
        <dt><kbd>↑</kbd> · <kbd>↓</kbd></dt>
        <dd>walk through recent command history (last 20)</dd>
        <dt><kbd>Enter</kbd></dt>
        <dd>run the parsed command or apply the highlighted completion</dd>
        <dt><kbd>Escape</kbd></dt>
        <dd>close the command bar without running anything</dd>
      </dl>

      <h3>command bar commands</h3>
      <dl class="dl-grid cmd">
        <dt><code>open &lt;path&gt;</code></dt>
        <dd>
          open a file from the current workspace; activates the existing buffer if already open
        </dd>

        <dt><code>write</code></dt>
        <dd>save the active buffer</dd>

        <dt><code>writeas &lt;path&gt;</code></dt>
        <dd>save the active buffer to another path</dd>

        <dt><code>quit</code></dt>
        <dd>exit the editor</dd>

        <dt><code>sidebar</code></dt>
        <dd>toggle the sidebar</dd>

        <dt><code>tree</code> · <code>editor</code></dt>
        <dd>focus the file tree / focus the editor</dd>

        <dt><code>reload</code></dt>
        <dd>reload the workspace tree</dd>

        <dt><code>next</code> · <code>prev</code></dt>
        <dd>activate the next / previous open buffer</dd>

        <dt><code>buffers &lt;id-or-name&gt;</code></dt>
        <dd>switch to an open buffer by numeric id or name</dd>

        <dt><code>theme &lt;name&gt;</code></dt>
        <dd>
          switch the accent color — tab through <code>green</code>, <code>blue</code>, <code
            >orange</code
          >, <code>cyan</code>, <code>teal</code>, <code>yellow</code>, <code>red</code>;
          live-previews each as you cycle
        </dd>

        <dt><code>recent &lt;path&gt;</code></dt>
        <dd>pick a recently opened file; tab cycles through the last 20</dd>

        <dt><code>help</code></dt>
        <dd>show command help in the dock panel</dd>
      </dl>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- THEMES                                                       -->
  <!-- ============================================================ -->
  <section id="themes" class="section">
    <div class="container">
      <div class="section__head"><h2>themes</h2></div>
      <p class="section__lede">
        Seven accent palettes. The dock title, status bar, selection highlight, and current-line
        gutter swap together; the grayscale chrome stays constant. Switch with <code
          >theme &lt;name&gt;</code
        > in the command bar.
      </p>
      <div class="theme-grid">
        {themes.map((theme) => <ThemeCard theme={theme} />)}
      </div>
    </div>
  </section>

  <!-- ============================================================ -->
  <!-- ARCHITECTURE                                                 -->
  <!-- ============================================================ -->
  <section id="architecture" class="section section--alt">
    <div class="container">
      <div class="section__head"><h2>how it works</h2></div>

      <p class="arch-p">
        fedit is built as an Elm-style update loop. The <code>Model</code> is pure data. <code
          >Editor.update</code
        > is a pure function that takes a <code>Msg</code> and returns a new model plus a list of effects.
        <code>runEffect</code> is the only impure code path — it does file I/O and folds its result back
        into the loop as another <code>Msg</code>. <code>Layout.render</code> projects the model to a
        <code>Screen</code>, and <code>Renderer.render</code> writes that grid as ANSI escapes.
      </p>

      <TuiFrame label="data flow">
        <Fragment
          set:html={`                        +----------------------+
                        |        Model         |
                        |  workspace . tree    |
                        |  buffers + cursors   |
                        |  focus, theme,       |
                        |  panels, terminal    |
                        +-----+----------+-----+
                              |          |
              read by         |          |     read by
        +---------------------+          +---------------------+
        |                                                      |
        v                                                      v
+-----------------+                                  +-------------------+
|  <span class="accent">Editor.update</span>  |                                  |   <span class="accent">Layout.render</span>   |
|     (pure)      |                                  |      (pure)       |
+--------+--------+                                  +---------+---------+
         |                                                     |
   (model', effects)                                        Screen
         |                                                     |
         v                                                     v
+-----------------+                                  +-------------------+
|    runEffect    |                                  |  <span class="accent">Renderer.render</span>  |
|    (impure)     |                                  |   ANSI escapes    |
|  ScanWorkspace  |                                  +---------+---------+
|  LoadFile       |                                            |
|  SaveBuffer     |                                            v
+--------+--------+                                     terminal output
         |
         v
        Msg  ----------> dispatch &lt;---------- KeyPressed / Resize
                            ^                       (main loop)
                            |
                       feeds back`}
        />
      </TuiFrame>

      <h3>buffer storage</h3>
      <p class="arch-p">
        Text buffers use a piece table. The original file contents stay in one string, inserted text
        is appended to another string, and the visible document is represented as a list of pieces.
        Inserts and deletes stay local to the piece list while preserving enough state for undo and
        redo snapshots.
      </p>

      <h3>files and encoding</h3>
      <p class="arch-p">
        Files are read as UTF-8. The line ending of the loaded file (<code>LF</code> or <code
          >CRLF</code
        >) is detected and reused on save; the buffer always works in <code>\n</code> form internally.
        Saving writes UTF-8 without a byte-order mark.
      </p>

      <h3>concurrency</h3>
      <p class="arch-p">
        The workspace scan, file open, file save, clipboard, and config writes all run on the thread
        pool via <code>Task.Run</code>. The main loop drains a <code
          >ConcurrentQueue&lt;Msg&gt;</code
        > of completed effects each tick, so input never blocks behind I/O. <code
          >ScanWorkspace</code
        > and <code>LoadFile</code> each carry a single <code>CancellationTokenSource</code> so a second
        invocation drops the previous result.
      </p>
    </div>
  </section>
</Site>

<style>
  /* ----- hero ----- */
  .hero {
    padding: var(--space-6) 0;
    background: var(--surface-1);
    border-top: none;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-5);
    align-items: center;
  }
  @media (max-width: 800px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }
  .hero-brand {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }
  .hero h1 {
    font-size: clamp(48px, 9vw, 72px);
    line-height: 1;
  }
  .hero-lede {
    font-family: "Departure Mono", "JetBrains Mono", monospace;
    font-size: clamp(20px, 3.2vw, 26px);
    line-height: 1.35;
    color: var(--fg);
    margin: 0 0 var(--space-4);
    max-width: 36ch;
  }
  .hero-key {
    color: var(--accent);
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: 0 0 var(--space-3);
  }
  .caveat {
    color: var(--fg-muted);
    font-size: 13px;
    margin: 0;
  }
  .hero-mascot {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  @media (max-width: 800px) {
    .hero-mascot {
      order: -1; /* mascot above text on mobile keeps brand-first reading */
      margin-bottom: var(--space-2);
    }
  }

  /* ----- CTA buttons ----- */
  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: "Departure Mono", "JetBrains Mono", monospace;
    font-size: 16px;
    letter-spacing: -0.01em;
    padding: 14px 22px;
    border-radius: 2px;
    text-decoration: none;
    transition:
      transform var(--t-fast) var(--ease),
      background var(--t-fast) var(--ease),
      border-color var(--t-fast) var(--ease),
      color var(--t-fast) var(--ease);
  }
  .cta-primary {
    background: var(--accent);
    color: var(--accent-fg);
    border: 1px solid var(--accent);
  }
  .cta-primary:hover {
    background: var(--accent-700);
    border-color: var(--accent-700);
    color: var(--neutral-50);
    transform: translateY(-1px);
  }
  .cta-primary:active {
    transform: translateY(0);
  }
  .cta-secondary {
    background: transparent;
    color: var(--fg);
    border: 1px solid var(--border-strong);
  }
  .cta-secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-1px);
  }
  .cta-secondary:active {
    transform: translateY(0);
  }

  /* ----- what (feature grid) ----- */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-4) var(--space-4);
  }
  .feature {
    padding: 0;
    background: none;
    border: none;
  }
  .feature h3 {
    font-family: "Departure Mono", "JetBrains Mono", monospace;
    font-size: 14px;
    color: var(--fg);
    text-transform: none;
    letter-spacing: -0.01em;
    margin-top: 0; /* override global h3 margin in this borderless-card context */
  }
  .feature p {
    color: var(--fg-muted);
    font-size: 13px;
    margin-top: var(--space-1);
    line-height: 1.55;
  }

  /* ----- prose helpers ----- */
  .muted-p {
    color: var(--fg-muted);
    max-width: 65ch;
    margin-top: var(--space-2);
  }
  .arch-p {
    color: var(--fg);
    max-width: 75ch;
  }
  .arch-p code {
    color: var(--fg);
  }
  .muted {
    color: var(--fg-muted);
    font-weight: 400;
  }
  .block {
    max-width: 720px;
  }

  /* ----- themes ----- */
  .theme-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-2);
  }

  /* command list — accent prefix on each item */
  .dl-grid.cmd dt::before {
    content: "›";
    color: var(--accent);
    margin-right: 6px;
  }
</style>
