---
import Site from "../layouts/Site.astro";
import CodeRain from "../components/mascots/CodeRain.astro";
import IdlePrompt from "../components/mascots/IdlePrompt.astro";
import GlyphRain from "../components/mascots/GlyphRain.astro";
import PhosphorBreath from "../components/mascots/PhosphorBreath.astro";

const variants = [
  {
    id: "A",
    title: "Code Rain",
    caption: "Dim F# source; a horizontal scanline brightens each line as it passes.",
    Component: CodeRain,
  },
  {
    id: "B",
    title: "Idle Prompt",
    caption: "Wordmark above a `>` prompt; a ghost types 3 chars every 7s and decays.",
    Component: IdlePrompt,
  },
  {
    id: "C",
    title: "Glyph Rain",
    caption: "Sparse Matrix-style drops in 10 columns; wordmark sits centered, untouched.",
    Component: GlyphRain,
  },
  {
    id: "D",
    title: "Phosphor Breath",
    caption: "Wordmark opacity breathes 1.0 → 0.55 → 1.0 over 6s; faint scanline crosses.",
    Component: PhosphorBreath,
  },
];
---

<Site>
  <section class="section">
    <div class="container">
      <header class="lab-head">
        <h1>mascot lab</h1>
        <p class="lab-lede">
          Four ambient CRT/phosphor variants for the hero. Pick the one that feels right.
          Hidden URL — not linked from the site.
        </p>
      </header>

      <div class="lab-grid">
        {
          variants.map(({ id, title, caption, Component }) => (
            <article class="lab-cell">
              <div class="lab-stage">
                <Component />
              </div>
              <div class="lab-meta">
                <h2>
                  <span class="lab-id">{id}</span>
                  <span class="lab-title">{title}</span>
                </h2>
                <p>{caption}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Site>

<style>
  .lab-head {
    margin-bottom: 2.5rem;
  }
  .lab-lede {
    color: var(--muted, #9a9aa1);
    max-width: 60ch;
    margin-top: 0.5rem;
  }

  .lab-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .lab-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .lab-cell {
    border: 1px solid var(--border, #27272a);
    border-radius: 6px;
    overflow: hidden;
    background: var(--bg-elev, #0b0b0d);
    display: flex;
    flex-direction: column;
  }

  .lab-stage {
    padding: 1.5rem;
    background:
      radial-gradient(circle at 50% 40%, rgba(0, 184, 107, 0.04), transparent 70%),
      var(--bg, #0b0b0d);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
  }

  .lab-meta {
    padding: 1rem 1.25rem 1.25rem;
    border-top: 1px solid var(--border, #27272a);
  }
  .lab-meta h2 {
    margin: 0 0 0.4rem;
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    font-size: 1rem;
  }
  .lab-id {
    font-family: "Departure Mono", "JetBrains Mono", monospace;
    color: var(--accent, #00b86b);
    font-size: 0.95rem;
  }
  .lab-title {
    font-weight: 600;
  }
  .lab-meta p {
    margin: 0;
    color: var(--muted, #9a9aa1);
    font-size: 0.9rem;
    line-height: 1.45;
  }
</style>
