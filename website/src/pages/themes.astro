---
import Site from "../layouts/Site.astro";
import ThemeCard from "../components/ThemeCard.astro";
import { themes } from "../data/themes";
---

<Site
  title="themes"
  description="Twelve themes ship with fedit, including two full-surface light/dark GitHub palettes. A theme owns the whole editor surface — editor, gutter, status bar, selection, prompt, and dock. Switch live from the command bar."
  image="/og/themes.png"
>
  <section class="section">
    <div class="container stack stack--lg">
      <div class="section__head">
        <h1>themes</h1>
        <p class="section__lede">
          Twelve themes — ten accent palettes plus full-surface <code>github-light</code> and <code
            >github-dark</code
          >. A theme owns the whole surface: editor, gutter, active line, status bar, selection,
          prompt, dock, and syntax. Switch with <code>theme &lt;name&gt;</code> in the command bar — every
          theme live-previews as you cycle through completions.
        </p>
      </div>

      <section>
        <div class="theme-grid">
          {themes.map((theme) => <ThemeCard theme={theme} />)}
        </div>
      </section>

      <section>
        <p class="muted-p">
          Themes ship as JSON in <code>brand/themes/*.json</code> and the F# implementation lives in
          <code>src/Fedit/Themes.fs</code>.
        </p>
      </section>
    </div>
  </section>
</Site>

<style>
  .theme-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-2);
  }
</style>
