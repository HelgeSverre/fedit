---
import type { Theme } from "../data/themes";
import ThemeEditorPreview from "./ThemeEditorPreview.astro";
interface Props {
  theme: Theme;
}
const { theme } = Astro.props;
---

<article class="theme-card card" style={`--accent:${theme.accent};`}>
  <header>
    <span class="dot" aria-hidden="true"></span>
    <span class="name">{theme.name}</span>
    {theme.isDefault && <span class="label">default</span>}
  </header>
  <ThemeEditorPreview theme={theme} />
  <footer>
    <span>{theme.description}</span>
    <code>{theme.accent} · {theme.appearance}</code>
  </footer>
</article>

<style>
  /* Surface chrome (fill/border/radius/transition + hover border) comes from
     the shared .card base in global.css. */
  .theme-card {
    overflow: hidden;
  }
  .theme-card:hover {
    transform: translateY(-2px);
  }
  .theme-card:focus-within {
    border-color: var(--accent);
    outline: 3px solid var(--accent-soft);
    outline-offset: 2px;
  }
  header {
    font-family: var(--font-departure-mono);
    font-size: 14px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  header .dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    background: var(--accent);
    border-radius: 50%;
  }
  header .name {
    color: var(--fg);
  }
  header .label {
    margin-left: auto;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--accent);
    background: color-mix(in oklch, var(--accent) 12%, transparent);
    padding: 2px 6px;
    border-radius: 2px;
  }
  footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    font-size: 11px;
    color: var(--fg-subtle);
    padding: 10px 14px;
    border-top: 1px solid var(--border);
  }
  footer code {
    background: transparent;
    border: none;
    padding: 0;
    color: var(--fg-muted);
    font-size: 11px;
  }
</style>
