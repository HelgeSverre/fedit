---
/**
 * A bordered terminal-output frame. Accepts a slot for plain text content;
 * content should be wrapped in classes (.dim, .muted, .accent) for ANSI-style
 * coloring. Bulletproof monospace via the .tui class in global.css.
 */
interface Props {
  label?: string;
  accent?: string;
  class?: string;
}
const { label, accent, class: className = "" } = Astro.props;
const style = accent ? `--accent:${accent};` : undefined;
const content = await Astro.slots.render("default");
const trimmed = content.trimEnd();
---

<div class={`tui-frame frame ${className}`} style={style}>
  {label && <div class="tui-frame__label frame__label">{label}</div>}
  <pre class="tui" set:html={trimmed} />
</div>

<style>
  /* Frame surface + label bar come from the shared .frame in global.css. */
  pre.tui {
    margin: 0;
    border: none;
    background: transparent;
    padding: 16px 18px;
    font-size: 11px;
    line-height: 1.55;
    white-space: pre;
    overflow-x: auto;
  }
</style>
