---
/**
 * Ambient mascot: dim F# source code with a slow horizontal scanline that
 * "lights up" each line as it passes — CRT phosphor persistence.
 *
 * Pure CSS keyframes. No JS. 360x140 viewBox to match the hero slot.
 */

const lines = [
  "let private classify (c: char) =",
  "  if isWordChar c then WordChar",
  "  elif isWs c then Whitespace",
  "  elif isPunct c then Punctuation",
  "  else Other",
  "",
  "let moveRightWord landing buf =",
  "  let i = wordIndexRight landing ...",
];
---

<div class="mascot mascot--rain">
  <svg viewBox="0 0 360 140" role="img" aria-label="fedit ambient code rain">
    <defs>
      <clipPath id="rain-clip">
        <rect x="0" y="0" width="360" height="140"></rect>
      </clipPath>
    </defs>
    <g clip-path="url(#rain-clip)">
      <g class="code" font-family="Departure Mono, JetBrains Mono, monospace" font-size="11">
        {
          lines.map((line, i) => (
            <text x="10" y={16 + i * 15} fill="var(--accent)" class={`line line-${i}`}>
              {line}
            </text>
          ))
        }
      </g>
      <!-- Scanline: thin horizontal band that sweeps top to bottom. -->
      <rect class="scan" x="0" y="-20" width="360" height="18" fill="var(--accent)"></rect>
    </g>
  </svg>
</div>

<style>
  .mascot--rain {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--fg);
  }
  svg {
    width: 100%;
    max-width: 360px;
    height: auto;
    display: block;
  }
  .line {
    opacity: 0.22;
    animation: line-pulse 8s linear infinite;
  }
  /* Staggered pulse: each line brightens briefly when the scanline crosses it. */
  .line-0 { animation-delay: 0s; }
  .line-1 { animation-delay: 0.75s; }
  .line-2 { animation-delay: 1.5s; }
  .line-3 { animation-delay: 2.25s; }
  .line-4 { animation-delay: 3s; }
  .line-5 { animation-delay: 3.75s; }
  .line-6 { animation-delay: 4.5s; }
  .line-7 { animation-delay: 5.25s; }

  @keyframes line-pulse {
    0%, 100% { opacity: 0.22; }
    4% { opacity: 0.85; }
    12% { opacity: 0.22; }
  }

  .scan {
    opacity: 0.08;
    animation: scan-sweep 8s linear infinite;
  }
  @keyframes scan-sweep {
    0% { transform: translateY(0); }
    100% { transform: translateY(160px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .line { opacity: 0.35; animation: none; }
    .scan { display: none; }
  }
</style>
