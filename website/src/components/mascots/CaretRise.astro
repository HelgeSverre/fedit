---
/**
 * Ambient mascot: a sparse field of `^` carets rises from below the frame,
 * drifts upward at varied speeds, brightens at mid-height, then fades out
 * past the top. Echoes the brand mark (which IS a caret) without repeating
 * the wordmark already shown beside the logo.
 *
 * Pure CSS keyframes. No JS. 360x140 viewBox.
 */

// Spread across the width; varied durations + delays so the field never
// pulses in unison. Sizes alternate so the depth reads as parallax.
const carets = [
  { x: 22, size: 14, dur: 6.4, delay: 0.0 },
  { x: 48, size: 18, dur: 8.2, delay: 1.7 },
  { x: 76, size: 12, dur: 5.6, delay: 3.4 },
  { x: 104, size: 22, dur: 9.1, delay: 0.9 },
  { x: 132, size: 14, dur: 6.8, delay: 4.1 },
  { x: 160, size: 16, dur: 7.4, delay: 2.2 },
  { x: 188, size: 20, dur: 8.6, delay: 5.0 },
  { x: 214, size: 12, dur: 5.9, delay: 0.4 },
  { x: 242, size: 18, dur: 7.8, delay: 3.0 },
  { x: 270, size: 14, dur: 6.2, delay: 1.3 },
  { x: 298, size: 22, dur: 9.4, delay: 4.6 },
  { x: 326, size: 16, dur: 7.1, delay: 2.5 },
];
---

<div class="mascot mascot--caret">
  <svg viewBox="0 0 360 140" role="img" aria-label="fedit ambient caret rise">
    <defs>
      <clipPath id="caret-clip">
        <rect x="0" y="0" width="360" height="140"></rect>
      </clipPath>
    </defs>
    <g clip-path="url(#caret-clip)">
      <g font-family="Departure Mono, JetBrains Mono, monospace" fill="var(--accent)">
        {
          carets.map((c) => (
            <text
              x={c.x}
              y="160"
              font-size={c.size}
              text-anchor="middle"
              class="caret"
              style={`animation-duration: ${c.dur}s; animation-delay: ${c.delay}s;`}
            >
              ^
            </text>
          ))
        }
      </g>
    </g>
  </svg>
</div>

<style>
  .mascot--caret {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--fg);
  }
  svg {
    width: 100%;
    max-width: 360px;
    height: auto;
    display: block;
  }

  .caret {
    opacity: 0;
    animation-name: caret-rise;
    animation-iteration-count: infinite;
    animation-timing-function: linear;
  }
  /* Rise 180px so each caret enters from below the 140px frame and exits
   * cleanly past the top. Opacity ramps up, peaks at mid-flight, then decays. */
  @keyframes caret-rise {
    0% {
      transform: translateY(0);
      opacity: 0;
    }
    15% {
      opacity: 0.35;
    }
    50% {
      transform: translateY(-90px);
      opacity: 0.95;
    }
    85% {
      opacity: 0.35;
    }
    100% {
      transform: translateY(-180px);
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .caret {
      animation: none;
      opacity: 0;
    }
  }
</style>
