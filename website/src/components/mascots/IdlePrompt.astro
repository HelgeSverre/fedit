---
/**
 * Ambient mascot: dim `fedit` wordmark with a `>` prompt below it. Every ~7s
 * a "ghost" types 3 characters at the prompt, then they decay back to empty.
 * Cursor blinks continuously.
 *
 * Pure CSS keyframes. No JS. 360x140 viewBox.
 */
---

<div class="mascot mascot--prompt">
  <svg viewBox="0 0 360 140" role="img" aria-label="fedit idle prompt">
    <text
      x="180"
      y="56"
      text-anchor="middle"
      font-family="Departure Mono, JetBrains Mono, monospace"
      font-size="36"
      fill="currentColor"
      class="wordmark">fedit</text
    >
    <g font-family="Departure Mono, JetBrains Mono, monospace" font-size="18">
      <text x="80" y="110" fill="var(--accent)" class="caret">&gt;</text>
      <text x="100" y="110" fill="currentColor" class="ghost g1">$</text>
      <text x="115" y="110" fill="currentColor" class="ghost g2">w</text>
      <text x="130" y="110" fill="currentColor" class="ghost g3">_</text>
      <rect class="cursor" x="100" y="96" width="10" height="16" fill="var(--accent)"></rect>
    </g>
  </svg>
</div>

<style>
  .mascot--prompt {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--fg);
  }
  svg {
    width: 100%;
    max-width: 360px;
    height: auto;
    display: block;
  }
  .wordmark {
    opacity: 0.5;
  }
  .caret { opacity: 0.6; }

  /* Ghost glyphs appear in sequence, hold, then fade out. 7s cycle. */
  .ghost {
    opacity: 0;
    animation: ghost 7s ease-in-out infinite;
  }
  .g1 { animation-delay: 1s; }
  .g2 { animation-delay: 1.4s; }
  .g3 { animation-delay: 1.8s; }

  @keyframes ghost {
    0%, 12% { opacity: 0; }
    16% { opacity: 0.7; }
    45% { opacity: 0.7; }
    65% { opacity: 0; }
    100% { opacity: 0; }
  }

  /* Cursor advances with the ghost typing, then resets. */
  .cursor {
    animation:
      cursor-advance 7s steps(1, end) infinite,
      cursor-blink 1s steps(2, start) infinite;
  }
  @keyframes cursor-advance {
    0%, 14% { transform: translateX(0); }
    15%, 19% { transform: translateX(15px); }
    20%, 24% { transform: translateX(30px); }
    25%, 65% { transform: translateX(45px); }
    66%, 100% { transform: translateX(0); }
  }
  @keyframes cursor-blink {
    50% { opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ghost { animation: none; opacity: 0; }
    .cursor { animation: cursor-blink 1.6s steps(2, start) infinite; transform: translateX(0); }
  }
</style>
