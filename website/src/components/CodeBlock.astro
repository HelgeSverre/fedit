---
import { Code } from "astro:components";

interface Props {
  code?: string;
  lang?: string;
  highlight?: boolean;
  class?: string;
}

const { code, lang = "sh", highlight = false, class: extraClass } = Astro.props;
---

{
  highlight && code ? (
    <div class:list={["codeblock-wrap", extraClass]}>
      <Code
        code={code}
        lang={lang}
        themes={{ light: "github-light", dark: "github-dark" }}
        defaultColor={false}
      />
    </div>
  ) : (
    <pre class:list={[extraClass]}><slot /></pre>
  )
}

<style>
  .codeblock-wrap :global(pre.astro-code) {
    background: var(--surface-2) !important;
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 14px 18px;
    font-family: var(--font-jetbrains-mono);
    font-feature-settings:
      "calt" 0,
      "liga" 0;
    font-size: 12px;
    line-height: 1.55;
    margin: 16px 0;
    overflow-x: auto;
    tab-size: 2;
  }

  /* Light theme colors by default */
  .codeblock-wrap :global(.astro-code),
  .codeblock-wrap :global(.astro-code) span {
    color: var(--shiki-light);
  }

  @media (prefers-color-scheme: dark) {
    .codeblock-wrap :global(.astro-code),
    .codeblock-wrap :global(.astro-code) span {
      color: var(--shiki-dark) !important;
    }
  }
</style>
