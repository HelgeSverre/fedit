---
/**
 * Hero mascot: 'fedit' types out char-by-char in Departure Mono with a
 * blinking accent-green block cursor. Pure CSS keyframes — no JS.
 *
 * Cycle is 5s: ~1.5s typing, ~3s holding with blinking cursor, brief reset.
 *
 * For monospace fonts at this size, advance width ≈ 0.62 * font-size.
 * Departure Mono at 80px → ~50px advance. Tune if it drifts.
 *
 * Reduced-motion: skip the typing cycle, show the final state with the
 * cursor blinking gently.
 */
---

<div class="mascot">
  <svg viewBox="0 0 360 140" role="img" aria-label="fedit (typing animation)">
    <text
      x="10"
      y="100"
      font-family="Departure Mono, JetBrains Mono, monospace"
      font-size="80"
      fill="currentColor"
    >
      <tspan class="ch c1">f</tspan><tspan class="ch c2">e</tspan><tspan
        class="ch c3">d</tspan><tspan class="ch c4">i</tspan><tspan
        class="ch c5">t</tspan>
    </text>
    <rect class="cursor" x="10" y="36" width="12" height="68" fill="var(--accent)"></rect>
  </svg>
</div>

<style>
  .mascot {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--fg);
  }
  svg {
    width: 100%;
    max-width: 360px;
    height: auto;
    display: block;
  }

  /* Each letter is invisible until its slot. The order goes: cursor sits at
   * position N, then letter N appears under it, then cursor moves to N+1. */
  .ch {
    opacity: 0;
    animation: reveal 5s steps(1, end) infinite;
  }
  .c1 {
    animation-delay: 0.4s;
  }
  .c2 {
    animation-delay: 0.7s;
  }
  .c3 {
    animation-delay: 1s;
  }
  .c4 {
    animation-delay: 1.3s;
  }
  .c5 {
    animation-delay: 1.6s;
  }

  @keyframes reveal {
    0%,
    73% {
      opacity: 1;
    }
    /* Hold visible most of the cycle. */
    74%,
    100% {
      opacity: 0;
    }
  }

  /* Block cursor — moves rightward as letters appear, then holds and blinks
   * at the end. transform on SVG elements: supported in all modern browsers. */
  .cursor {
    animation:
      cursor-move 5s steps(1, end) infinite,
      cursor-blink 1s steps(2, start) infinite;
  }

  @keyframes cursor-move {
    0%,
    7% {
      transform: translateX(0);
    }
    8%,
    13% {
      transform: translateX(50px);
    } /* after f */
    14%,
    19% {
      transform: translateX(100px);
    } /* after e */
    20%,
    25% {
      transform: translateX(150px);
    } /* after d */
    26%,
    31% {
      transform: translateX(200px);
    } /* after i */
    32%,
    73% {
      transform: translateX(250px);
    } /* after t — hold */
    74%,
    100% {
      transform: translateX(0);
    } /* reset for next cycle */
  }

  @keyframes cursor-blink {
    50% {
      opacity: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ch {
      opacity: 1;
      animation: none;
    }
    .cursor {
      transform: translateX(250px);
      animation: cursor-blink 1.6s steps(2, start) infinite;
    }
  }
</style>
