default:
    @just --list

# Install JavaScript dependencies
deps:
    bun install

[private]
deps-if-needed:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ ! -d node_modules ]; then
        bun install
    fi

# Run the Astro dev server (http://localhost:4321 by default)
[group('run')]
dev: deps-if-needed
    bun run dev

# Build the static site to dist/
[group('build')]
build: deps-if-needed og
    bun run build

# Generate Open Graph cards (1200x630 PNGs in public/og/)
[group('build')]
og: deps-if-needed
    bun scripts/gen-og.mjs

# Preview the production build locally
[group('build')]
preview: deps-if-needed
    bun run preview

# Type-check the site
[group('test')]
check: deps-if-needed lint
    bun run check

# Format website source: oxfmt for ts/tsx/css/md/mjs/json, prettier for astro
[group('format')]
format: deps-if-needed
    bun x oxfmt "**/*.{ts,tsx,css,md,mjs,json}"
    bun x prettier --write "**/*.astro"

# Lint with oxlint and check formatting with oxfmt + prettier
[group('format')]
lint: deps-if-needed
    bun x oxlint .
    bun x oxfmt --check "**/*.{ts,tsx,css,md,mjs,json}"
    bun x prettier --check "**/*.astro"

# Remove build artifacts
[group('build')]
clean:
    rm -rf dist .astro

# Nuke everything (deps + build artifacts)
[group('build')]
nuke: clean
    rm -rf node_modules bun.lock
